{
    "freqai": {
        "enabled": true,
        "purge_old_models": 2,
        "train_period_days": 45,
        "backtest_period_days": 7,
        "live_retrain_hours": 60,
        "fit_live_predictions_candles": 240,
        "expiration_hours": 72,
        "identifier": "production_rolling_lgb_cpu",
        "concurrent_training": false,
        "feature_parameters": {
            "include_timeframes": [
                "15m"
            ],
            "include_corr_pairlist": [],
            "label_period_candles": 20,
            "clip_dataset_tiling": false,
            "weight_factor": 0,
            "indicator_periods_candles": [
                14,
                50
            ],
            "include_shifted_candles": 0,
            "plot_feature_importances": 0,
            "DI_threshold": 0,
            "use_SVM_to_remove_outliers": false
        },
        "data_split_parameters": {
            "test_size": 0.2,
            "random_state": 42,
            "shuffle": false
        },
        "model_training_parameters": {
            "_comment": "objective/metric are absent intentionally: LightGBMClassifierCPU enforces multiclass+multi_logloss internally; LightGBMRegressorCPU defaults to regression+rmse. Adding them here would corrupt whichever model type is NOT in use.",
            "n_estimators": 250,
            "learning_rate": 0.05,
            "num_leaves": 31,
            "max_depth": 6,
            "max_bin": 127,
            "n_jobs": 4,
            "subsample": 0.8,
            "colsample_bytree": 0.8,
            "importance_type": "gain"
        }
    }
}
