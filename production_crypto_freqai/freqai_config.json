{
    "freqai": {
        "enabled": true,
        "purge_old_models": true,
        "train_period_days": 45,
        "backtest_period_days": 7,
        "live_retrain_hours": 60,
        "fit_live_predictions_candles": 240,
        "expiration_hours": 12,
        "identifier": "production_rolling_lgb_cpu",
        "concurrent_training": false,
        "feature_parameters": {
            "include_timeframes": [
                "15m",
                "1h"
            ],
            "include_corr_pairlist": [
                "BTC/USDT",
                "ETH/USDT"
            ],
            "label_period_candles": 20,
            "clip_dataset_tiling": false,
            "weight_factor": 0,
            "indicator_periods_candles": [
                14,
                21,
                50,
                100
            ],
            "plot_feature_importances": 10
        },
        "data_split_parameters": {
            "test_size": 0.2,
            "random_state": 42,
            "shuffle": false
        },
        "model_training_parameters": {
            "n_estimators": 250,
            "learning_rate": 0.05,
            "num_leaves": 31,
            "max_depth": 6,
            "max_bin": 127,
            "n_jobs": 4,
            "objective": "regression",
            "metric": "rmse",
            "histogram_pool_size": 1024,
            "device_type": "cpu",
            "subsample": 0.8,
            "colsample_bytree": 0.8,
            "importance_type": "gain"
        }
    }
}
